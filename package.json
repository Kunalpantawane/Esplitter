{
  "name": "esplitter",
  "version": "1.0.0",
  "description": "Offline-First Group Expense Tracker",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "dev": "concurrently \"vite\" \"nodemon server/app.js\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon server/app.js",
    "test": "jest --runInBand --no-cache",
    "cleanup:expenses": "node server/scripts/cleanExpenseData.js",
    "migrate:group-roles:dry": "node server/scripts/backfillGroupRoles.js --dry-run",
    "migrate:group-roles": "node server/scripts/backfillGroupRoles.js --write",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "supertest": "^7.1.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
