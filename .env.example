# MongoDB — use local install or free Atlas cluster
MONGODB_URI=mongodb://localhost:27017/esplitter

# JWT secrets — use long random strings in production
JWT_SECRET=change_me_to_a_random_string

# Server port
PORT=3000

# CORS — comma-separated origins (defaults to http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5500

# Environment — 'development' or 'production'
# NODE_ENV=development

# Redis — optional, for production-ready payment idempotency (defaults to in-memory cache)
# REDIS_URL=redis://localhost:6379

# Razorpay API keys (get from https://dashboard.razorpay.com/settings/api-keys)
# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Payment service configuration
# RAZORPAY_WEBHOOK_RETRY_ATTEMPTS=3
# RAZORPAY_WEBHOOK_TIMEOUT_MS=30000
